{
  "schema_version": "spatialrust.vision2-workload-manifest.v1",
  "profiles": {
    "vga": { "width": 640, "height": 480 },
    "1080p": { "width": 1920, "height": 1080 },
    "4k": { "width": 3840, "height": 2160 }
  },
  "required_component_stages": [
    "python_conversion",
    "allocation",
    "native_kernel",
    "upload",
    "execution",
    "readback"
  ],
  "required_metrics": [
    "mpix_per_second",
    "ns_per_pixel",
    "bytes_allocated",
    "peak_workspace_bytes"
  ],
  "required_workload_fields": ["allocation_mode", "batch_policy"],
  "thread_modes": ["single", "default"],
  "workloads": [
    { "id": "resize_bilinear", "native_criterion": { "bench": "resize", "group": "resize_bilinear_rgb8" } },
    { "id": "rgb_to_gray", "native_criterion": { "bench": "preprocess", "group": "rgb_to_gray_rgb8" } },
    { "id": "ai_preprocess", "native_criterion": { "bench": "preprocess", "group": "resize_normalize_chw_rgb8" } },
    { "id": "gaussian_blur", "native_criterion": { "bench": "filter", "group": "gaussian_blur_rgb8_5x5" } },
    { "id": "sobel_x", "native_criterion": { "bench": "filter", "group": "paired_sobel_3x3/x_f32_direct" } },
    { "id": "morphology_open", "native_criterion": { "bench": "morphology", "group": "morphology_open_gray8_5x5" } },
    { "id": "canny", "native_criterion": { "bench": "canny", "group": "canny" } },
    { "id": "distance_transform_edt", "native_criterion": { "bench": "dense", "group": "distance_transform_edt" } }
  ]
}
